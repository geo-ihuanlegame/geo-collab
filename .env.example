# ============================================================
# Geo Collab 环境变量配置模板
# 复制为 .env 后填入真实值，docker-compose 和 app 共用此文件
# 本模板假设部署在 Linux 服务器（Docker Compose）。本项目不支持 Windows 桌面部署。
# 发布 worker 只运行 1 个实例；不要使用 docker compose --scale worker=N。
# ============================================================

# 飞书机器人 Webhook URL（可选，配置后任务完成时推送通知）
# GEO_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here

# ---------- MySQL 数据库 ----------
# MySQL root 密码（必填）
MYSQL_ROOT_PASSWORD=change_me_root

# MySQL 数据库名（默认 geo_collab）
MYSQL_DATABASE=geo_collab

# MySQL 应用用户（默认 geo_user）
MYSQL_USER=geo_user

# MySQL 应用用户密码（必填）
MYSQL_PASSWORD=change_me_user

# ---------- 应用数据库连接 ----------
# 推荐方式：使用独立凭据（密码含特殊字符时无需手动 URL-encode）
# docker-compose 已自动从 MYSQL_* 变量填充以下配置，无需在 .env 中重复设置
# GEO_DB_HOST=mysql
# GEO_DB_PORT=3306
# GEO_DB_USER=geo_user
# GEO_DB_PASS=change_me_user
# GEO_DB_NAME=geo_collab
#
# 备用方式：直接提供完整 URL（密码含特殊字符需手动 URL-encode）
# GEO_DATABASE_URL=mysql+pymysql://geo_user:change_me_user@mysql:3306/geo_collab

# ---------- JWT 鉴权 ----------
# JWT 签名密钥（必填，用 openssl rand -hex 32 生成）
GEO_JWT_SECRET=change_me_jwt_secret_64_chars_minimum

# ---------- 初始用户 ----------
# 系统初始化时的种子用户，JSON 数组格式
# 示例: [{"username":"admin","password":"admin123"}]
GEO_SEED_USERS=change_me_json_array

# ---------- AI 生文 ----------
# 注意：以下 GEO_AI_* 仅供 web UI 的"方案运行"、自动排版（ai_format）等走 GEO 后端 LiteLLM
# 的路径使用。**Claude Code MCP loop（claude-loops/*.md）不依赖这些 key**——loop 内的
# 写作由 Claude Code 主对话直接产出 markdown 后调 save_article 落库（零配置）。
#
# 调用的模型 ID（LiteLLM 格式，**必须带 provider 前缀**：anthropic/、openai/、deepseek/ 等）
# LiteLLM 1.40+ 不再自动猜 provider，无前缀串会被拒（BadRequestError: "LLM Provider NOT provided"）。
# GEO_AI_MODEL=anthropic/claude-3-5-sonnet-20241022

# API Key（Anthropic 填 sk-ant-…；OpenAI 填 sk-…；留空则 web UI 方案运行 / 自动排版不可用）
# GEO_AI_API_KEY=

# 可选写作引擎列表（JSON 数组）。下拉「模型」从这里取；每项自带 api_key/base_url，
# 选哪个就用哪个的凭据，无需改上面的 GEO_AI_MODEL/GEO_AI_API_KEY。
# model 空=用 GEO_AI_MODEL；api_key 空=回落 GEO_AI_API_KEY；base_url 仅 OpenAI 兼容网关需要。
# 同样要求 model 串带 provider 前缀。
# GEO_AI_ENGINES=[{"label":"Claude","model":"anthropic/claude-3-5-sonnet-20241022","api_key":"sk-ant-…"},{"label":"DeepSeek","model":"deepseek/deepseek-chat","api_key":"sk-…"},{"label":"公司网关","model":"openai/gpt-4o","api_key":"sk-…","base_url":"https://oneapi.mycorp/v1"}]

# ---------- AI 格式调整（小标题识别）----------
# 用于识别文章小标题的模型（LiteLLM 格式；推荐轻量级模型降低成本）
# GEO_AI_FORMAT_MODEL=deepseek/deepseek-v4-flash

# AI 格式调整的 API Key（DeepSeek 填 sk-…；留空则 AI格式 按钮不可用）
# GEO_AI_FORMAT_API_KEY=

# ---------- 本地 API Token ----------
# 本地 API 鉴权 token（可选，留空则自动生成）
# GEO_LOCAL_API_TOKEN=

# ---------- 数据目录 ----------
# 应用持久化数据目录（Docker 内使用 /app/data）
GEO_DATA_DIR=/app/data

# ---------- 远程浏览器（发布时需要）----------
# Xvfb 可执行文件路径
GEO_PUBLISH_XVFB_PATH=Xvfb

# x11vnc 可执行文件路径
GEO_PUBLISH_X11VNC_PATH=x11vnc

# websockify 可执行文件路径
GEO_PUBLISH_WEBSOCKIFY_PATH=websockify

# noVNC 静态文件目录（Debian 包默认路径）
GEO_PUBLISH_NOVNC_WEB_DIR=/usr/share/novnc

# noVNC 在容器内监听地址；docker-compose 只绑定宿主机 127.0.0.1
GEO_PUBLISH_REMOTE_BROWSER_HOST=0.0.0.0

# ---------- 远程浏览器高级配置（可选）----------
# X display 起始编号（默认 99）
# GEO_PUBLISH_REMOTE_BROWSER_DISPLAY_BASE=99

# VNC 端口起始值（默认 5900）
# GEO_PUBLISH_REMOTE_BROWSER_VNC_BASE_PORT=5900

# noVNC 端口起始值（默认 6080）
# GEO_PUBLISH_REMOTE_BROWSER_NOVNC_BASE_PORT=6080

# Xvfb/VNC/noVNC 启动超时秒数（默认 15）
# GEO_PUBLISH_REMOTE_BROWSER_START_TIMEOUT_SECONDS=15

# 浏览器空闲超时秒数（默认 300，无操作后自动清理）
# GEO_PUBLISH_REMOTE_BROWSER_IDLE_TIMEOUT_SECONDS=300

# ---------- 发布引擎 ----------
# 最大并发发布记录数（默认 5，上限 5；生产建议先设 2 或 3 降低平台风控）
# GEO_PUBLISH_MAX_CONCURRENT_RECORDS=3

# 单条发布记录超时秒数（默认 300）
# GEO_PUBLISH_RECORD_TIMEOUT_SECONDS=300

# 浏览器渠道（默认 chromium）
# GEO_PUBLISH_BROWSER_CHANNEL=chromium

# 浏览器可执行文件路径（可选，Chromium 通常自动发现）
# GEO_PUBLISH_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium

# MCP server（POC 期生成方式：openssl rand -hex 32）
# GEO_MCP_TOKEN=changeme-generate-with-openssl-rand-hex-32
# GEO_API_BASE_URL — MCP server (~/.claude.json) 端使用，指向 GEO HTTP API
# （服务端 .env 不需要它；这里仅作为「外网部署后写到客户端 ~/.claude.json 的值」示意）
# GEO_API_BASE_URL=http://127.0.0.1:8000
